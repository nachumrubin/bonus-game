{
  "database": {
    "rules": "firebase.database.rules.json"
  },
  "emulators": {
    "database": {
      "port": 9000
    },
    "auth": {
      "port": 9099
    },
    "hosting": {
      "port": 5000
    },
    "ui": {
      "enabled": true,
      "port": 4000
    },
    "singleProjectMode": true
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".git/**",
      ".gitignore",
      ".firebaseignore",
      "node_modules/**",
      "worker/**",
      "android/**",
      "scripts/**",
      "tests/**",
      "tools/**",
      "package.json",
      "package-lock.json",
      "playwright.config.js",
      "firebase.database.rules.json",
      "*.keystore",
      "*.jks",
      "keystore.properties",
      "app/**",
      "build/**",
      ".gradle/**",
      "gradle/**",
      "gradlew",
      "gradlew.bat",
      "build.gradle",
      "settings.gradle",
      "gradle.properties",
      "manifest-checksum.txt"
    ],
    "headers": [
      {
        "source": "/.well-known/assetlinks.json",
        "headers": [
          { "key": "Content-Type", "value": "application/json" }
        ]
      }
    ]
  }
}
