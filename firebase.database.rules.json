{
  "rules": {
    "rooms": {
  	".read": true,
  	".write": true
		},
    "dictionarySuggestions": {
      ".read": true,
      ".write": true
    },
    "dictionaryApproved": {
      ".read": true,
      ".write": "auth != null && auth.token.admin === true"
    },
    "dictionaryRejected": {
      ".read": true,
      ".write": "auth != null && auth.token.admin === true"
    },
    "globalChampions": {
      ".read": true,
      ".write": "auth != null",
      ".indexOn": ["score"]
    }
  }
}
