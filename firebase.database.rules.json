{
  "rules": {
    "rooms": {
  	".read": true,
  	".write": true
		},
    "dictionarySuggestions": {
      ".read": true,
      ".write": true
    },
    "dictionaryApproved": {
      ".read": true,
      ".write": true
    },
    "dictionaryRejected": {
      ".read": true,
      ".write": true
    },
    "globalChampions": {
      ".read": true,
      ".write": true,
      ".indexOn": ["score"]
    },
    "usernames": {
      ".read": true,
      "$username": {
        ".write": "!data.exists() || data.val() === auth.uid"
      }
    },
    "users": {
      "$uid": {
        ".read": "$uid === auth.uid",
        ".write": "$uid === auth.uid"
      }
    },
    "userIds": {
      ".read": true,
      "$userId": {
        ".write": "auth != null && (!data.exists() || data.val() === auth.uid)"
      }
    },
    "friendRequests": {
      "$recipientUid": {
        ".read": "$recipientUid === auth.uid",
        "$senderUid": {
          ".write": "auth != null"
        }
      }
    },
    "friends": {
      "$uid": {
        ".read": "$uid === auth.uid",
        "$friendUid": {
          ".write": "auth != null && (auth.uid === $uid || auth.uid === $friendUid)"
        }
      }
    },
    "invites": {
      "$recipientUid": {
        ".read": "$recipientUid === auth.uid",
        "$senderUid": {
          ".write": "auth != null"
        }
      }
    },
    "inviteResponses": {
      "$inviterUid": {
        "$inviteeUid": {
          ".read": "auth != null && auth.uid === $inviterUid",
          ".write": "auth != null && (auth.uid === $inviterUid || auth.uid === $inviteeUid)"
        }
      }
    }
  }
}
