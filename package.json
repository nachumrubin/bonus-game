{
  "name": "bonus-game",
  "private": true,
  "version": "1.0.0",
  "description": "Test harness for bonus-game",
  "scripts": {
    "test:unit": "node --test tests/unit/*.test.js",
    "test:emulator": "firebase emulators:exec --project demo-bonus-game --only database \"node --test --test-concurrency=1 tests/emulator/*.test.mjs\"",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "dict:add": "node scripts/add-dictionary-words.js",
    "dict:export": "node scripts/export-dictionary-file.js"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@playwright/test": "^1.60.0",
    "firebase": "^12.13.0",
    "firebase-tools": "^15.18.0"
  }
}
