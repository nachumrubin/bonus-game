{
  "name": "bonus-game",
  "private": true,
  "version": "1.0.0",
  "description": "Test harness for bonus-game",
  "scripts": {
    "test:unit": "node --test tests/unit/*.test.js",
    "test:emulator": "firebase emulators:exec --project demo-bonus-game --only database \"node --test --test-concurrency=1 tests/emulator/*.test.mjs\"",
    "test:e2e": "playwright test",
    "sim": "node scripts/simulator/launch.mjs",
    "emu": "firebase emulators:start --project demo-bonus-game --only auth,database,hosting",
    "test:e2e:headed": "playwright test --headed",
    "dict:absorb": "node scripts/absorb-firebase-dict.mjs",
    "find-room": "node scripts/find-room.mjs"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@playwright/test": "^1.60.0",
    "firebase": "^12.13.0",
    "firebase-tools": "^15.18.0"
  },
  "dependencies": {
    "firebase-admin": "^14.1.0"
  }
}
